@inherits LayoutComponentBase
@using RaceTimerApp.Shared.Services
@inject NavigationManager Navigation
@inject RaceManagementService RaceService
@inject TimingService TimingService

<div class="main-container">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-brand">RaceTimer</span>
        </div>
        <div class="sidebar-new-race">
            <button class="btn btn-success btn-lg btn-block new-race-btn" @onclick="CreateNewRace">
                <span class="oi oi-plus"></span> Neues Rennen
            </button>
        </div>
        <nav class="sidebar-nav">
            <ul>
                <li><a href="/" class="nav-link">Home</a></li>
                <li><a href="/races" class="nav-link">Rennen</a></li>
                <li><a href="/overview" class="nav-link">Übersicht</a></li>
                <li><a href="/timing" class="nav-link">Zeiterfassung</a></li>
                <li><a href="/penalty" class="nav-link">Strafzeiten</a></li>
                <li><a href="/standings" class="nav-link">Zwischenstand</a></li>
                <li><a href="/settings" class="nav-link">Einstellungen</a></li>
                <li><a href="/guide" class="nav-link">📖 Anleitung</a></li>
            </ul>
        </nav>
    </aside>

    <div class="main-content">
        @Body
    </div>

    <!-- Timing Button - immer sichtbar wenn Rennen läuft -->
    @if (_hasRunningRace)
    {
        <div class="timing-button-container">
            <button class="btn btn-primary btn-lg timing-button" @onclick="RecordTimePoint" title="Zeitpunkt erfassen">
                <span class="oi oi-clock"></span> Zeit erfassen
            </button>
            @if (_hasUnassignedPoints)
            {
                <a href="/timing" class="btn btn-warning btn-lg timing-secondary" title="Offene Zeitpunkte zuordnen">
                    <span class="badge badge-danger">!</span>
                </a>
            }
        </div>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _hasRunningRace = false;
    private bool _hasUnassignedPoints = false;

    protected override async Task OnInitializedAsync()
    {
        await CheckRunningRaces();
        _ = CheckHasUnassignedTimePointsAsync();
    }

    private async Task CheckRunningRaces()
    {
        var running = await RaceService.GetRunningRacesAsync();
        _hasRunningRace = running.Any();
    }

    private async Task CheckHasUnassignedTimePointsAsync()
    {
        await TimingService.LoadUnassignedTimePointsAsync();
        _hasUnassignedPoints = TimingService.GetUnassignedTimePoints().Any();
    }

    private async Task RecordTimePoint()
    {
        await TimingService.RecordTimePointAsync();

        _ = CheckHasUnassignedTimePointsAsync();
    }

    private async Task CreateNewRace()
    {
        // Erstelle einen eindeutigen Namen mit Timestamp
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
        var newRace = await RaceService.CreateRaceAsync($"Neues Rennen {timestamp}");

        if (newRace != null)
        {
            Navigation.NavigateTo($"/races/{newRace.Id}");
        }
    }
}
