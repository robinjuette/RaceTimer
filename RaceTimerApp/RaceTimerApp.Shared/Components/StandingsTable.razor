@using RaceTimerApp.Shared.Services
@using RaceTimer.Shared.Models
@inject RankingService RankingService

<div class="standings-component">
    <h3>Zwischenstände</h3>

    @if (Rankings == null)
    {
        <p>Lädt...</p>
    }
    else if (!Rankings.Any())
    {
        <p class="text-muted">Keine Zwischenstände</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Platz</th>
                        <th>Teilnehmer</th>
                        <th>Start Nr.</th>
                        <th>Zeit</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (rank, entry) in Rankings.Select((r, i) => (i + 1, r)))
                    {
                        <tr>
                            <td>
                                <strong>@rank</strong>
                            </td>
                            <td>@entry.Participant.DisplayName</td>
                            <td>@entry.ParticipantNr</td>
                            <td>
                                @if (entry.FinishDateTimeUTC.HasValue)
                                {
                                    @TimeSpan.FromSeconds((entry.FinishDateTimeUTC.Value - entry.StartTime.Value).TotalSeconds).ToString(@"hh\:mm\:ss")
                                }
                                else
                                {
                                    <span class="badge badge-warning">läuft...</span>
                                }
                            </td>
                            <td>
                                @if (entry.FinishDateTimeUTC.HasValue)
                                {
                                    <span class="badge badge-success">Fertig</span>
                                }
                                else if (entry.StartTime <= DateTime.UtcNow)
                                {
                                    <span class="badge badge-info">Läuft</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Wartet</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .standings-component {
        margin: 20px 0;
    }

    .standings-component h3 {
        margin-bottom: 20px;
        font-weight: 600;
    }

    .table-responsive {
        border-radius: 4px;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead {
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .table th {
        font-weight: 600;
        color: #495057;
        padding: 12px 15px;
        border: none;
    }

    .table td {
        padding: 12px 15px;
        vertical-align: middle;
    }

    .table tbody tr:hover {
        background: #f8f9fa;
    }

    .badge {
        font-size: 0.75rem;
        padding: 0.35em 0.65em;
    }
</style>

@code {
    [Parameter]
    public IEnumerable<RaceParticipant>? Rankings { get; set; }
}
