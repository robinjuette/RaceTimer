@using RaceTimer.Shared.Models
@using RaceTimerApp.Shared.Services

<div class="card race-card mb-3">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h5 class="card-title">@Race.Name</h5>
                <p class="card-text text-muted">
                    @if (Race.StartTimeUTC.HasValue)
                    {
                        <span>Start: @Race.StartTimeUTC.Value.ToLocalTime():G</span>
                    }
                    @if (Race.FinishDateTimeUTC.HasValue)
                    {
                        <span class="ms-3">Ende: @Race.FinishDateTimeUTC.Value.ToLocalTime():G</span>
                    }
                </p>
            </div>
            <div class="col-md-4">
                <span class="badge badge-lg @GetStatusBadgeClass()">
                    @GetStatusText()
                </span>
            </div>
            <div class="col-md-2 text-end">
                <div class="btn-group" role="group" style="width: 100%; display: flex; gap: 5px; flex-wrap: wrap; justify-content: flex-end;">
                    @if (Race.RaceStatus == RaceStatus.Finished)
                    {
                        <button class="btn btn-success btn-sm" @onclick="OnShowResults" title="Endergebnisse ansehen">Ergebnisse</button>
                    }
                    else if (Race.RaceStatus == RaceStatus.Running)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="OnShowStandings" title="Zwischenstand ansehen">Zwischenstand</button>
                    }
                    <button class="btn btn-primary btn-sm" @onclick="OnManage" title="Rennen verwalten">Verwalten</button>
                    <button class="btn btn-danger btn-sm" @onclick="OnDelete" title="Rennen löschen">Löschen</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Race Race { get; set; } = new();

    [Parameter]
    public EventCallback OnShowStandings { get; set; }

    [Parameter]
    public EventCallback OnShowResults { get; set; }

    [Parameter]
    public EventCallback OnManage { get; set; }

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private string GetStatusText()
    {
        return Race.RaceStatus switch
        {
            RaceStatus.Finished => "Beendet",
            RaceStatus.Running => "AAAAHHHH ES LÄÄÄÄUUUUUFT!",
            _ => "Geplant"
        };
    }

    private string GetStatusBadgeClass()
    {
        return Race.RaceStatus switch
        {
            RaceStatus.Finished => "bg-success",
            RaceStatus.Running => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
