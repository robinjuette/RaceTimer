@page "/timing"
@using RaceTimerApp.Shared.Services
@using RaceTimer.Shared.Models
@using RaceTimerApp.Shared.Models
@using RaceTimerApp.Shared.Helpers
@inject RaceManagementService RaceService
@inject ParticipantService ParticipantService
@inject RankingService RankingService
@inject TimingService TimingService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="timing-container">
    <div class="timing-left-column">
        <!-- Offene Zeitpunkte -->
        <div class="card mb-3">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Offene Zeitpunkte <span class="badge bg-danger">@UnassignedTimePoints.Count</span></h5>
            </div>
            <div class="card-body">
                @if (UnassignedTimePoints.Any())
                {
                    <div class="list-group">
                        @foreach (var tp in UnassignedTimePoints)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center"
                                 @onclick="() => SelectTimePoint(tp)" 
                                 style="cursor: pointer; background-color: @(SelectedTimePoint?.Id == tp.Id ? "#e7f3ff" : "")">
                                <div>
                                    <strong>@tp.TimePointUTC.ToLocalTime().ToString("HH:mm:ss")</strong>
                                    <br />
                                    <small class="text-muted">Erfasst vor @((DateTime.UtcNow - tp.TimePointUTC).FormatShort())</small>
                                </div>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteTimePoint(tp.Id)">Löschen</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">Keine offenen Zeitpunkte</div>
                }
            </div>
        </div>
    </div>

    <!-- Teilnehmer zur Zuordnung -->
    <div class="timing-right-column">
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Aktive Teilnehmer</h5>
            </div>
            <div class="card-body">
                @if (AvailableFTPs.Any())
                {
                    <div style="display:flex; flex-direction:row; flex-wrap:wrap">
                        @foreach (FutureRaceParticipantTimePoint ftp in AvailableFTPs)
                        {
                            <div @onclick="() => SelectFTP(ftp)"
                                 class="participant-item active"
                                 style="cursor: pointer; margin:1%; background-color: @(SelectedFTP?.Race.Id == ftp.Race.Id && SelectedFTP?.RaceParticipant.ParticipantID == ftp.RaceParticipant.ParticipantID ? "#e7f3ff" : "#cccccc33")">
                                <div style="display:flex; flex-direction:column;">
                                    
                                    <div style="display:flex; flex-direction:row;">

                                        <strong class="participant-number" style="align-self:center">#@ftp.RaceParticipant.ParticipantNr</strong>

                                        <div style="display:flex; flex-direction:column;">
                                            <span class="participant-name">@ftp.RaceParticipant.Participant.DisplayName</span>
                                            <span>@ftp.RaceTimePoint.DisplayName</span>
                                        </div>
                                    </div>
                                    @if (_multipleRaces)
                                    {
                                        <strong style="text-align:center; text-wrap:auto">@ftp.Race.Name</strong>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">Keine aktiven Teilnehmer</div>
                }
            </div>
        </div>

        @if (SelectedTimePoint is not null && SelectedFTP is not null)
        {
            <div class="card">
                <div class="card-body">
                    <button class="btn btn-success btn-assign-timepoint" @onclick="AssignTimePoint">
                        <span class="oi oi-check"></span> Zeitpunkt zuordnen
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<style>
.timing-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.timing-left-column {
    min-width: 0;
}

.timing-right-column {
    min-width: 0;
}

.btn-assign-timepoint {
    width: 100%;
    padding: 15px 20px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 6px;
    min-height: 50px;
}
</style>

@code {
    private List<RaceParticipantTimePoint> UnassignedTimePoints = [];
    private RaceParticipantTimePoint? SelectedTimePoint;
    private FutureRaceParticipantTimePoint? SelectedFTP;
    private List<FutureRaceParticipantTimePoint> AvailableFTPs = [];
    private TimingServiceUpdateEndpoint? updateEndpoint;
    private bool _multipleRaces = false;

    protected override async Task OnInitializedAsync()
    {
        updateEndpoint = new(TimingPoint_Changed);
        TimingService.RegisterForCallback(updateEndpoint);
        await LoadData();
        _ = UIRefresh();
    }

    
    private async Task UIRefresh()
    {
        while (true)
        {
            await Task.Delay(1000);
            StateHasChanged();
        }
    }

    private void TimingPoint_Changed(RaceParticipantTimePoint? changed)
    {
        _ = LoadData();
    }

    private async Task LoadData()
    {
        List<Race> runningRaces = (await RaceService.GetRunningRacesAsync()).ToList();

        _multipleRaces = runningRaces.Count > 1;

        AvailableFTPs.Clear();
        foreach (Race race in runningRaces)
        {
            List<RankingEntry> rankings = await RankingService.GetRankingsAsync(race.Id);
            List<RaceTimePoint> raceTimePoints = (await RaceService.GetRaceTimePointsAsync(race.Id)).ToList();

            foreach (RankingEntry rankingEntry in rankings.Where(re => re.SplitTimes.Any(s => s.Value.HasValue) && !re.SplitTimes.All(s => s.Value.HasValue)))
            {
                uint minOpenIndex = rankingEntry.SplitTimes.Where(s => !s.Value.HasValue).Min(s => s.Key);

                FutureRaceParticipantTimePoint ftp = new()
                    {
                        Race = race,
                        RaceParticipant = rankingEntry.RaceParticipant,
                        RaceTimePoint = raceTimePoints.First(rtp => rtp.Index == minOpenIndex)
                    };

                AvailableFTPs.Add(ftp);
            }
        }

        UnassignedTimePoints = await TimingService.GetUnassignedTimePointsAsync();

        StateHasChanged();
    }

    private void SelectTimePoint(RaceParticipantTimePoint tp)
    {
        SelectedTimePoint = tp.Id == SelectedTimePoint?.Id ? null : tp;
    }

    private void SelectFTP(FutureRaceParticipantTimePoint p)
    {
        SelectedFTP = p;
    }

    private async Task AssignTimePoint()
    {
        if (SelectedTimePoint is null || SelectedFTP is null)
            return;

        await TimingService.AssignTimePointAsync(
            SelectedTimePoint.Id,
            SelectedFTP.Value.Race.Id,
            SelectedFTP.Value.RaceParticipant.ParticipantID);

        await LoadData();
        SelectedTimePoint = null;
        SelectedFTP = null;
    }

    private async Task DeleteTimePoint(Guid id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Wirklich löschen?"))
        {
            await TimingService.DeleteTimePointAsync(id);
            await LoadData();
        }
    }

    private struct FutureRaceParticipantTimePoint
    {
        public required RaceParticipant RaceParticipant { get; init; }
        public required RaceTimePoint RaceTimePoint { get; init; }
        public required Race Race { get; init; }
    }
}
