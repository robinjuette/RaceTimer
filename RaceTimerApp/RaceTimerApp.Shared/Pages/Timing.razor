@page "/timing"
@using RaceTimerApp.Shared.Services
@using RaceTimer.Shared.Models
@inject RaceManagementService RaceService
@inject ParticipantService ParticipantService
@inject TimingService TimingService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="timing-container">
    <div class="timing-left-column">
        <!-- Offene Zeitpunkte -->
        <div class="card mb-3">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Offene Zeitpunkte <span class="badge bg-danger">@UnassignedTimePoints.Count</span></h5>
            </div>
            <div class="card-body">
                @if (UnassignedTimePoints.Any())
                {
                    <div class="list-group">
                        @foreach (var tp in UnassignedTimePoints)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center"
                                 @onclick="() => SelectTimePoint(tp)" 
                                 style="cursor: pointer; background-color: @(SelectedTimePoint?.Id == tp.Id ? "#e7f3ff" : "")">
                                <div>
                                    <strong>@tp.TimePointUTC.ToLocalTime().ToString("HH:mm:ss")</strong>
                                    <br />
                                    <small class="text-muted">@((DateTime.UtcNow - tp.TimePointUTC).TotalSeconds) Sekunden alt</small>
                                </div>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteTimePoint(tp.Id)">Löschen</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">Keine offenen Zeitpunkte</div>
                }
            </div>
        </div>
    </div>

    <!-- Teilnehmer zur Zuordnung -->
    <div class="timing-right-column">
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Aktive Teilnehmer</h5>
            </div>
            <div class="card-body">
                @if (ActiveParticipants.Any())
                {
                    <div class="list-group">
                        @foreach (var (race, participant) in ActiveParticipants)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center"
                                 @onclick="() => SelectParticipant((race, participant))"
                                 style="cursor: pointer; background-color: @(SelectedParticipant?.Item1.Id == race.Id && SelectedParticipant?.Item2.ParticipantID == participant.ParticipantID ? "#e7f3ff" : "")">
                                <div>
                                    <strong>#@participant.ParticipantNr - @participant.Participant?.DisplayName</strong>
                                    @if (ActiveParticipants.Where(p => p.race.Id == race.Id).Count() > 1)
                                    {
                                        <br />
                                        <small class="text-muted">@race.Name</small>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">Keine aktiven Teilnehmer</div>
                }
            </div>
        </div>

        @if (SelectedTimePoint is not null && SelectedParticipant is not null)
        {
            <div class="card">
                <div class="card-body">
                    <button class="btn btn-success btn-assign-timepoint" @onclick="AssignTimePoint">
                        <span class="oi oi-check"></span> Zeitpunkt zuordnen
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<style>
.timing-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.timing-left-column {
    min-width: 0;
}

.timing-right-column {
    min-width: 0;
}

.btn-assign-timepoint {
    width: 100%;
    padding: 15px 20px;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 6px;
    min-height: 50px;
}
<!--
//@media (max-width: 768px) {
    .timing-container {
        grid-template-columns: 1fr;
    }
}-->
</style>

@code {
    private List<RaceParticipantTimePoint> UnassignedTimePoints = [];
    private RaceParticipantTimePoint? SelectedTimePoint;
    private (Race, RaceParticipant)? SelectedParticipant;
    private List<(Race race, RaceParticipant participant)> ActiveParticipants = [];
    private List<Race> RunningRaces = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _ = AutoRefresh();
    }

    private async Task LoadData()
    {
        RunningRaces = (await RaceService.GetRunningRacesAsync()).ToList();

        ActiveParticipants.Clear();
        foreach (var race in RunningRaces)
        {
            foreach (var participant in (await ParticipantService.GetRaceParticipantsAsync(race.Id)).Where(rp => rp.StartTime.HasValue && !rp.FinishDateTimeUTC.HasValue))
            {
                ActiveParticipants.Add((race, participant));
            }
        }

        UnassignedTimePoints = TimingService.GetUnassignedTimePoints().ToList();
    }

    private async Task AutoRefresh()
    {
        while (true)
        {
            await Task.Delay(2000); // Alle 2 Sekunden refresh
            await LoadData();
            StateHasChanged();
        }
    }

    private void SelectTimePoint(RaceParticipantTimePoint tp)
    {
        SelectedTimePoint = tp.Id == SelectedTimePoint?.Id ? null : tp;
    }

    private void SelectParticipant((Race, RaceParticipant) p)
    {
        SelectedParticipant = p.Item2.ParticipantID == SelectedParticipant?.Item2.ParticipantID ? null : p;
    }

    private async Task AssignTimePoint()
    {
        if (SelectedTimePoint is null || SelectedParticipant is null)
            return;

        await TimingService.AssignTimePointAsync(
            SelectedTimePoint.Id,
            SelectedParticipant.Value.Item2.RaceID,
            SelectedParticipant.Value.Item2.ParticipantID);

        await LoadData();
        SelectedTimePoint = null;
        SelectedParticipant = null;
    }

    private async Task DeleteTimePoint(Guid id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Wirklich löschen?"))
        {
            await TimingService.DeleteTimePointAsync(id);
            await LoadData();
        }
    }
}
