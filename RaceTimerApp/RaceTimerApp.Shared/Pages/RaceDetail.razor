@page "/races/{RaceId}"
@using RaceTimerApp.Shared.Services
@using RaceTimer.Shared.Models
@using Microsoft.AspNetCore.Components.Web
@inject RaceManagementService RaceService
@inject ParticipantService ParticipantService
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (CurrentRace is null)
{
    <div class="alert alert-danger">Rennen nicht gefunden</div>
    return;
}

<div class="page-header">
    <div>
        @if (IsEditingName)
        {
            <div class="input-group" style="max-width: 400px;">
                <input type="text" class="form-control" @bind="EditRaceName" placeholder="Rennname"/>
                <button class="btn btn-primary" @onclick="SaveRaceName">Speichern</button>
                <button class="btn btn-secondary" @onclick="CancelEditName">Abbrechen</button>
            </div>
        }
        else
        {
            <h1>@CurrentRace.Name <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditName()" title="Rennen umbenennen">✎</button></h1>
        }
    </div>
    @if (CurrentRace?.RaceStatus == RaceStatus.Running)
    {
        <a href="/overview/@RaceId" class="btn btn-primary">Zur Rennübersicht</a>
    }
    @if (CurrentRace?.RaceStatus != RaceStatus.Planned)
    {
        <a href="/standings/@RaceId" class="btn btn-primary">Zum Rennstand</a>
    }

    <button class="btn btn-secondary" @onclick="GoBack">Zurück</button>
</div>

<!-- Status Badge -->
<div class="mb-3">
    <span class="badge badge-lg @GetStatusBadgeClass()">@GetStatusText()</span>
</div>

<!-- Zeitpunkte & Zeitanzeige -->
<div class="row mb-3">
    <div class="col-md-6">
        <p><strong>Start:</strong> @(CurrentRace.StartTimeUTC?.ToLocalTime().ToString("G") ?? "Nicht gestartet")</p>
    </div>
    <div class="col-md-6">
        <p><strong>Ende:</strong> @(CurrentRace.FinishDateTimeUTC?.ToLocalTime().ToString("G") ?? "Nicht beendet")</p>
    </div>
</div>

<!-- Rennzeitpunkte - für alle Status -->
<div class="card mb-3">
    <div class="card-header">
        <h5>Rennzeitpunkte</h5>
    </div>
    <div class="card-body">
        @if (CurrentRace?.RaceStatus == RaceStatus.Planned)
        {
            <div class="row mb-3">
                <div class="col-md-9">
                    <input type="text" class="form-control" placeholder="Name des Zeitpunkts" @bind="NewTimePointName" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success" @onclick="AddTimePoint">Hinzufügen</button>
                </div>
            </div>
        }

        @if (CurrentRace.RaceTimePoints.Any())
        {
            <div class="timepoint-list">
                @foreach (var tp in DisplayTimePoints)
                {
                    @if (EditingTimePointId == tp.Id && CurrentRace?.RaceStatus == RaceStatus.Planned)
                    {
                        <div class="timepoint-item editing">
                            <div class="timepoint-handle">⋮⋮</div>
                            <div class="timepoint-content">
                                <span class="timepoint-index">@tp.Index</span>
                                <input type="text" class="form-control" @bind="EditTimePointName" />
                                <input type="checkbox" class="form-check-input ms-2" @bind="EditTimePointPenalty" />
                                <span class="timepoint-actions">
                                    <button class="btn btn-sm btn-primary" @onclick="() => SaveTimePoint(tp.Id)">Speichern</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="CancelEditTimePoint">Abbrechen</button>
                                </span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="timepoint-item" draggable="@(CurrentRace?.RaceStatus == RaceStatus.Planned ? "true" : "false")"
                             @ondragstart="@((DragEventArgs e) => OnDragStart(e, tp.Id))"
                             @ondrop="@((DragEventArgs e) => OnDrop(e, tp.Id))"
                             @ondragover="@((DragEventArgs e) => e.DataTransfer.DropEffect = "move")">
                            @if (CurrentRace?.RaceStatus == RaceStatus.Planned)
                            {
                                <div class="timepoint-handle">⋮⋮</div>
                            }
                            <div class="timepoint-content">
                                <span class="timepoint-index">@tp.Index</span>
                                <span class="timepoint-name">@tp.DisplayName</span>
                                @if (tp.HasPenaltyTime)
                                {
                                    <span class="timepoint-penalty" title="Strafzeit erforderlich">⏱️</span>
                                }
                                @if (CurrentRace?.RaceStatus == RaceStatus.Planned)
                                {
                                    <span class="timepoint-actions">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditTimePoint(tp)">Bearbeiten</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => RemoveTimePoint(tp.Id)">Löschen</button>
                                    </span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="alert alert-info">Keine Zeitpunkte. @(CurrentRace?.RaceStatus == RaceStatus.Planned ? "Mindestens 2 sind erforderlich um zu starten." : "")</div>
        }
    </div>
</div>

<!-- Teilnehmer -->
<div class="card mb-3">
    <div class="card-header">
        <h5>Teilnehmer</h5>
    </div>
    <div class="card-body">
        @if (CurrentRace?.RaceStatus != RaceStatus.Finished)
        {
            <div class="mb-3">
                <label class="form-label">Teilnehmer hinzufügen</label>
                <div class="input-group">
                    <input type="text" class="form-control" 
                           placeholder="Name oder Nummer eingeben..." 
                           @bind="NewParticipantName"
                           @oninput="@((ChangeEventArgs e) => OnParticipantInputChanged(e))" />
                    <button class="btn btn-success" @onclick="AddNewParticipant">Hinzufügen</button>
                </div>
                @if (SearchResults.Any())
                {
                    <div class="list-group mt-2" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var participant in SearchResults)
                        {
                            <button type="button" class="list-group-item list-group-item-action" 
                                    @onclick="() => SelectExistingParticipant(participant)">
                                @participant.DisplayName
                            </button>
                        }
                    </div>
                }
            </div>
        }

        @if (CurrentRace.RaceParticipants.Any())
        {
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Nr.</th>
                        <th>Name</th>
                        @if (CurrentRace?.RaceStatus != RaceStatus.Finished)
                        {
                            <th style="width: 50px;"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rp in CurrentRace.RaceParticipants.OrderBy(x => x.ParticipantNr))
                    {
                        <tr>
                            <td>@rp.ParticipantNr</td>
                            <td>@rp.Participant?.DisplayName</td>
                            @if (CurrentRace?.RaceStatus != RaceStatus.Finished)
                            {
                                <td>
                                    <button class="btn btn-sm btn-danger" @onclick="() => RemoveParticipant(rp.ParticipantID)">Entfernen</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info">Keine Teilnehmer</div>
        }
    </div>
</div>

@if (CurrentRace?.RaceStatus == RaceStatus.Planned)
{
    <div class="mb-3">
        <button class="btn btn-lg btn-success" @onclick="PrepareStart">Rennstart vorbereiten</button>
    </div>
}

@code {
    [Parameter]
    public string? RaceId { get; set; }

    private Race? CurrentRace;
    private string NewTimePointName = "";
    private string NewParticipantName = "";
    private List<Participant> SearchResults = [];

    // Für Rennen umbenennen
    private bool IsEditingName = false;
    private string EditRaceName = "";

    // Für TimePoint bearbeiten
    private Guid EditingTimePointId = Guid.Empty;
    private string EditTimePointName = "";
    private bool EditTimePointPenalty = false;

    // Für Drag & Drop
    private Guid? DraggedTimePointId = null;
    private List<RaceTimePoint> DisplayTimePoints = [];

    protected override async Task OnInitializedAsync()
    {
        if (RaceId == "new")
        {
            var newRace = await RaceService.CreateRaceAsync();
            if (newRace is not null)
            {
                Navigation.NavigateTo($"/races/{newRace.Id}");
                return;
            }
        }

        if (Guid.TryParse(RaceId, out var raceId))
        {
            CurrentRace = await RaceService.GetRaceAsync(raceId);
            if (CurrentRace is not null)
            {
                UpdateDisplayTimePoints();
            }
        }
    }

    private void UpdateDisplayTimePoints()
    {
        if (CurrentRace is not null)
        {
            DisplayTimePoints = CurrentRace.RaceTimePoints.OrderBy(x => x.Index).ToList();
        }
    }

    private void StartEditName()
    {
        IsEditingName = true;
        EditRaceName = CurrentRace?.Name ?? "";
    }

    private async Task SaveRaceName()
    {
        if (string.IsNullOrEmpty(EditRaceName) || CurrentRace is null)
            return;

        await RaceService.UpdateRaceNameAsync(CurrentRace.Id, EditRaceName);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
        IsEditingName = false;
    }

    private void CancelEditName()
    {
        IsEditingName = false;
        EditRaceName = "";
    }

    private void StartEditTimePoint(RaceTimePoint timePoint)
    {
        EditingTimePointId = timePoint.Id;
        EditTimePointName = timePoint.DisplayName;
        EditTimePointPenalty = timePoint.HasPenaltyTime;
    }

    private async Task SaveTimePoint(Guid timePointId)
    {
        if (string.IsNullOrEmpty(EditTimePointName) || CurrentRace is null)
            return;

        await RaceService.UpdateRaceTimePointAsync(CurrentRace.Id, timePointId, EditTimePointName, EditTimePointPenalty);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
        UpdateDisplayTimePoints();
        EditingTimePointId = Guid.Empty;
        EditTimePointName = "";
        EditTimePointPenalty = false;
    }

    private void CancelEditTimePoint()
    {
        EditingTimePointId = Guid.Empty;
        EditTimePointName = "";
        EditTimePointPenalty = false;
    }

    private async Task AddTimePoint()
    {
        if (string.IsNullOrEmpty(NewTimePointName) || CurrentRace is null)
            return;

        await RaceService.AddRaceTimePointAsync(CurrentRace.Id, NewTimePointName);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
        UpdateDisplayTimePoints();
        NewTimePointName = "";
    }

    private async Task RemoveTimePoint(Guid timePointId)
    {
        if (CurrentRace is null) return;
        await RaceService.DeleteRaceTimePointAsync(CurrentRace.Id, timePointId);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
        UpdateDisplayTimePoints();
    }

    // Drag & Drop Methoden
    private void OnDragStart(DragEventArgs e, Guid timePointId)
    {
        DraggedTimePointId = timePointId;
        if (e.DataTransfer is not null)
        {
            e.DataTransfer.EffectAllowed = "move";
        }
    }

    private async Task OnDrop(DragEventArgs e, Guid targetTimePointId)
    {
        if (DraggedTimePointId is null || CurrentRace is null || CurrentRace.RaceStatus != RaceStatus.Planned)
            return;

        if (DraggedTimePointId == targetTimePointId)
        {
            DraggedTimePointId = null;
            return;
        }

        var draggedIndex = DisplayTimePoints.FindIndex(tp => tp.Id == DraggedTimePointId);
        var targetIndex = DisplayTimePoints.FindIndex(tp => tp.Id == targetTimePointId);

        if (draggedIndex < 0 || targetIndex < 0)
        {
            DraggedTimePointId = null;
            return;
        }

        // Swap items
        var temp = DisplayTimePoints[draggedIndex];
        DisplayTimePoints.RemoveAt(draggedIndex);
        DisplayTimePoints.Insert(targetIndex, temp);

        // Aktualisiere Index-Werte
        for (int i = 0; i < DisplayTimePoints.Count; i++)
        {
            DisplayTimePoints[i].Index = (uint)(i + 1);
        }

        // Persistiere neue Reihenfolge
        var reorderedIds = DisplayTimePoints.Select(tp => tp.Id).ToList();
        await RaceService.ReorderRaceTimePointsAsync(CurrentRace.Id, reorderedIds);

        DraggedTimePointId = null;
        StateHasChanged();
    }

    private async Task SearchParticipants()
    {
        if (string.IsNullOrEmpty(NewParticipantName))
        {
            SearchResults.Clear();
            return;
        }

        var results = await ParticipantService.SearchParticipantsAsync(NewParticipantName);
        if (CurrentRace is not null)
        {
            var assignedIds = CurrentRace.RaceParticipants.Select(rp => rp.ParticipantID).ToHashSet();
            SearchResults = results.Where(p => !assignedIds.Contains(p.Id)).ToList();
        }
    }

    private async Task OnParticipantInputChanged(ChangeEventArgs e)
    {
        NewParticipantName = e.Value?.ToString() ?? "";
        await SearchParticipants();
    }

    private async Task SelectExistingParticipant(Participant p)
    {
        if (CurrentRace is null) return;
        await ParticipantService.AddParticipantToRaceAsync(CurrentRace.Id, p.DisplayName, p);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
        NewParticipantName = "";
        SearchResults.Clear();
    }

    private async Task AddNewParticipant()
    {
        if (string.IsNullOrEmpty(NewParticipantName) || CurrentRace is null)
            return;

        await ParticipantService.AddParticipantToRaceAsync(CurrentRace.Id, NewParticipantName);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
        NewParticipantName = "";
        SearchResults.Clear();
    }

    private async Task RemoveParticipant(Guid participantId)
    {
        if (CurrentRace is null) return;
        await ParticipantService.RemoveParticipantFromRaceAsync(CurrentRace.Id, participantId);
        CurrentRace = await RaceService.GetRaceAsync(CurrentRace.Id);
    }

    private async Task PrepareStart()
    {
        if (CurrentRace is null) return;
        Navigation.NavigateTo($"/races/{CurrentRace.Id}/start");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/races");
    }

    private string GetStatusText()
    {
        return CurrentRace?.RaceStatus switch
        {
            RaceStatus.Running => "Läuft",
            RaceStatus.Finished => "Beendet",
            _ => "Geplant"
        };
    }

    private string GetStatusBadgeClass()
    {
        return CurrentRace?.RaceStatus switch
        {
            RaceStatus.Running => "bg-danger",
            RaceStatus.Finished => "bg-success",
            _ => "bg-secondary"
        };
    }
}
