@page "/races"
@using RaceTimerApp.Shared.Services
@using RaceTimer.Shared.Models
@inject RaceManagementService RaceService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-header">
    <h1>Rennverwaltung</h1>
</div>

<!-- Reiter -->
<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(CurrentTab == RUNNING_TAB ? "active" : "")" @onclick="() => SwitchTab(RUNNING_TAB)">
            Laufende Rennen <span class="badge bg-info">@RunningRaces.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(CurrentTab == PLANNED_TAB ? "active" : "")" @onclick="() => SwitchTab(PLANNED_TAB)">
            Geplante Rennen <span class="badge bg-secondary">@PlannedRaces.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(CurrentTab == COMPLETED_TAB ? "active" : "")" @onclick="() => SwitchTab(COMPLETED_TAB)">
            Beendete Rennen <span class="badge bg-success">@FinishedRaces.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(CurrentTab == ALL_TAB ? "active" : "")" @onclick="() => SwitchTab(ALL_TAB)">
            Alle Rennen <span class="badge bg-dark">@AllRaces.Count</span>
        </button>
    </li>
</ul>

<!-- Race List -->
<div class="race-list">
    @if (DisplayedRaces.Any())
    {
        @foreach (var race in DisplayedRaces)
        {
            <RaceListItem Race="race" OnShowStandings="() => ShowRaceStandings(race.Id)" OnManage="() => ManageRace(race.Id)" OnDelete="() => DeleteRace(race.Id)" />
        }
    }
    else
    {
        <div class="alert alert-info">Keine Rennen in dieser Kategorie</div>
    }
</div>

@code {
    private List<Race> AllRaces = [];
    private List<Race> RunningRaces = [];
    private List<Race> PlannedRaces = [];
    private List<Race> FinishedRaces = [];
    private List<Race> DisplayedRaces = [];
    private string CurrentTab = RUNNING_TAB;
    private bool Loading = true;

    private const string RUNNING_TAB = "running";
    private const string PLANNED_TAB = "planned";
    private const string COMPLETED_TAB = "completed";
    private const string ALL_TAB = "all";

    protected override async Task OnInitializedAsync()
    {
        await LoadRaces();
        // Prüfe ob laufende Rennen existieren, sonst zeige geplante
        if (!RunningRaces.Any())
            CurrentTab = PLANNED_TAB;

        SetDisplayedRaces();
    }

    private async Task LoadRaces()
    {
        Loading = true;
        AllRaces = (await RaceService.GetAllRacesAsync()).ToList();
        RunningRaces = AllRaces.Where(r => r.RaceStatus == RaceStatus.Running).ToList();
        PlannedRaces = AllRaces.Where(r => r.RaceStatus == RaceStatus.Planned).ToList();
        FinishedRaces = AllRaces.Where(r => r.RaceStatus == RaceStatus.Finished).ToList();
        Loading = false;
        SetDisplayedRaces();
    }

    private void SwitchTab(string tab)
    {
        CurrentTab = tab;
        SetDisplayedRaces();
    }

    private void SetDisplayedRaces()
    {
        DisplayedRaces = CurrentTab switch
        {
            PLANNED_TAB => PlannedRaces,
            RUNNING_TAB => RunningRaces,
            COMPLETED_TAB => FinishedRaces,
            _ => AllRaces
        };
        
    }

    private void ManageRace(Guid raceId)
    {
        Navigation.NavigateTo($"/races/{raceId}");
    }

    private void ShowRaceStandings(Guid raceId)
    {
        Navigation.NavigateTo($"/standings/{raceId}");
    }

    private async Task DeleteRace(Guid raceId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Möchten Sie dieses Rennen wirklich löschen?"))
        {
            await RaceService.DeleteRaceAsync(raceId);
            await LoadRaces();
        }
    }

    private async Task CreateNewRace()
    {
        Race? newRace = await RaceService.CreateRaceAsync();

        if (newRace != null)
        {
            ManageRace(newRace.Id);
        }
    }
}
