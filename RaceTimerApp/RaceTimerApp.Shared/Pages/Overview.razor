@page "/overview"
@page "/overview/{RaceId}"
@using BlazorBootstrap
@using RaceTimerApp.Shared.Services
@using RaceTimerApp.Shared.Models
@using RaceTimer.Shared.Models
@inject RaceManagementService RaceService
@inject ParticipantService ParticipantService
@inject TimingService TimingService
@inject RankingService RankingService
@inject NavigationManager Navigation

<div class="page-header">
    <h1>Rennübersicht</h1>
</div>

@if (!RunningRaces.Any())
{
    <div class="alert alert-info">
        Keine laufenden Rennen. <a href="/races">Zur Rennverwaltung</a>
    </div>
    return;
}

<!-- Race Selector - nur wenn mehrere Rennen laufen -->
@if (RunningRaces.Count > 1)
{
    <div class="mb-3">
        <label for="raceSelect" class="form-label">Rennen auswählen:</label>
        <select id="raceSelect" class="form-select" @onchange="SelectRace">
            <option value="">Alle Rennen</option>
            @foreach (var race in RunningRaces)
            {
                <option value="@race.Id" selected="@(race.Id == SelectedRaceId)">@race.Name</option>
            }
        </select>
    </div>
}

<!-- Rennen Display Container -->
<div class="overview-container">
    @foreach (var race in DisplayRaces)
    {
        <div class="race-overview-card">
            <!-- Header mit Rennname (nur bei mehreren Rennen) -->
            @if (DisplayRaces.Count() > 1)
            {
                <div class="race-header">
                    <h4>@race.Name</h4>
                    <small class="text-muted">Gestartet: @race.StartTimeUTC?.ToLocalTime().ToString("G")</small>
                </div>
            }

            <div class="race-content">
                <!-- Linke Seite: Noch nicht gestartete Teilnehmer -->
                <div class="side-panel left-panel">
                    <div class="panel-header">
                        <h6>Noch nicht gestartet</h6>
                    </div>
                    @if (GetNotStartedParticipants(race).Any())
                    {
                        <div class="participant-list">
                            @foreach (var participant in GetNotStartedParticipants(race).OrderBy(p => p.ParticipantNr))
                            {
                                <div class="participant-item pending">
                                    <div class="participant-info">
                                        <span class="participant-number">@participant.ParticipantNr</span>
                                        <span class="participant-name">@participant.Participant?.DisplayName</span>
                                    </div>
                                    <div class="participant-actions">
                                        @if (_preparedParticipant?.ParticipantID == participant.ParticipantID)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => CancelPrepare()">Abbrechen</button>
                                            <button class="btn btn-sm btn-success" @onclick="() => StartParticipant(participant, race)">Start</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => PrepareStart(participant)">Vorbereiten</button>
                                            <button class="btn btn-sm btn-success" disabled>Start</button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted text-center py-3">Alle gestartet</div>
                    }
                </div>

                <!-- Mitte: Laufende Teilnehmer mit Fortschritt -->
                <div class="center-panel">
                    <div class="panel-header">
                        <h6>Aktive Teilnehmer</h6>
                    </div>
                    @if (GetActiveParticipants(race).Any())
                    {
                        <div class="participant-list">
                            @foreach (var participant in GetActiveParticipants(race).OrderBy(p => p.ParticipantNr))
                            {
                                var ranking = GetRankingEntry(race, participant);
                                <div class="participant-item active">
                                    <div class="participant-header">
                                        <span class="participant-number">@participant.ParticipantNr</span>
                                        <span class="participant-name">@participant.Participant?.DisplayName</span>
                                        <span class="participant-time">@FormatTimeSpan(ranking?.RunTime)</span>
                                        @if(ranking != null)
                                        {
                                            <span>Position @ranking.Position</span>
                                        }
                                    </div>
                                    @if (ranking != null)
                                    {
                                        <Progress Class="mb-3">
                                            <ProgressBar Width="ranking.ProgressPercent"/>
                                        </Progress>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted text-center py-3">Keine aktiven Teilnehmer</div>
                    }
                </div>

                <!-- Rechte Seite: Beendete Teilnehmer -->
                <div class="side-panel right-panel">
                    <div class="panel-header">
                        <h6>Beendet</h6>
                    </div>
                    @if (GetFinishedParticipants(race).Any())
                    {
                        <div class="participant-list">
                            @foreach (var participant in GetFinishedParticipants(race).OrderBy(p => p.ParticipantNr))
                            {
                                var ranking = GetRankingEntry(race, participant);
                                <div class="participant-item finished">
                                    <div class="participant-info">
                                        <span class="participant-number">@participant.ParticipantNr</span>
                                        <span class="participant-name">@participant.Participant?.DisplayName</span>
                                    </div>
                                    <div class="participant-time">
                                        @FormatTimeSpan(ranking?.RunTime)
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted text-center py-3">Noch niemand beendet</div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? RaceId { get; set; }

    private List<Race> RunningRaces = [];
    private Guid SelectedRaceId = Guid.Empty;
    private RaceParticipant? _preparedParticipant;

    private Dictionary<Guid, List<RankingEntry>> RaceRankings = new();
    private Dictionary<Guid, List<RaceParticipant>> RacesParticipants = new();
    private IEnumerable<Race> DisplayRaces
    {
        get
        {
            if (SelectedRaceId == Guid.Empty)
                return RunningRaces.Take(4);
            return RunningRaces.Where(r => r.Id == SelectedRaceId);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        TimingService.RegisterForCallback(new(TimePointChanged));

        await LoadRaces();

        if (Guid.TryParse(RaceId, out var raceId))
        {
            SelectedRaceId = raceId;
        }
        else if (RunningRaces.Count == 1)
        {
            // Auto-select wenn nur ein Rennen läuft
            SelectedRaceId = RunningRaces.First().Id;
        }

        // Auto-refresh
        _ = AutoRefresh();
    }

    private void TimePointChanged(RaceParticipantTimePoint? timePoint)
    {
        _ = LoadRaces();
    }

    private async Task LoadRaces()
    {
        var loaded = await RaceService.GetRunningRacesAsync();

        foreach (Race lr in loaded)
        {
            RacesParticipants[lr.Id] = (await ParticipantService.GetRaceParticipantsAsync(lr.Id)).ToList();
        }

        // Lade Rankings für alle Rennen
        foreach (var race in loaded)
        {
            var rankings = await RankingService.GetRankingsAsync(race.Id);
            RaceRankings[race.Id] = rankings;
        }

        RunningRaces = (await RaceService.GetRunningRacesAsync()).ToList();
    }

    private async Task AutoRefresh()
    {
        while (true)
        {
            await Task.Delay(1000);
            StateHasChanged();
        }
    }

    private void SelectRace(ChangeEventArgs e)
    {
        if (e.Value is not null && Guid.TryParse(e.Value.ToString(), out var raceId))
        {
            SelectedRaceId = raceId;
        }
        else
        {
            SelectedRaceId = Guid.Empty;
        }
    }

    private IEnumerable<RaceParticipant> GetNotStartedParticipants(Race race)
    {
        if (!RacesParticipants.ContainsKey(race.Id)) return Enumerable.Empty<RaceParticipant>();

        return RacesParticipants[race.Id].Where(rp => !rp.StartTime.HasValue);
    }

    private IEnumerable<RaceParticipant> GetActiveParticipants(Race race)
    {
        if (!RacesParticipants.ContainsKey(race.Id)) return Enumerable.Empty<RaceParticipant>();

        return RacesParticipants[race.Id].Where(rp => rp.StartTime.HasValue && !rp.FinishDateTimeUTC.HasValue);
    }

    private IEnumerable<RaceParticipant> GetFinishedParticipants(Race race)
    {
        if (!RacesParticipants.ContainsKey(race.Id)) return Enumerable.Empty<RaceParticipant>();

        return RacesParticipants[race.Id].Where(rp => rp.FinishDateTimeUTC.HasValue);
    }

    private bool HasReachedTimePoint(RaceParticipant participant, RaceTimePoint timePoint, Race race)
    {
        return race.RaceParticipantTimePoints.Any(rptp =>
            rptp.ParticipantID == participant.ParticipantID &&
            rptp.RaceTimePoint?.Id == timePoint.Id);
    }

    private DateTime? GetTimePointTime(RaceParticipant participant, RaceTimePoint timePoint, Race race)
    {
        return race.RaceParticipantTimePoints
            .FirstOrDefault(rptp =>
                rptp.ParticipantID == participant.ParticipantID &&
                rptp.RaceTimePoint?.Id == timePoint.Id)?
            .TimePointUTC;
    }

    private RankingEntry? GetRankingEntry(Race race, RaceParticipant participant)
    {
        if (!RaceRankings.TryGetValue(race.Id, out var rankings))
            return null;

        return rankings.FirstOrDefault(r => r.RaceParticipant.ParticipantID == participant.ParticipantID);
    }

    private string FormatTimeSpan(TimeSpan? timeSpan)
    {
        if (!timeSpan.HasValue)
            return "-";

        var ts = timeSpan.Value;
        if (ts.TotalHours >= 1)
            return $"{ts.Hours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}";
        else
            return $"{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    private void PrepareStart(RaceParticipant participant)
    {
        _preparedParticipant = participant;
    }

    private void CancelPrepare()
    {
        _preparedParticipant = null;
    }

    private async Task StartParticipant(RaceParticipant participant, Race race)
    {
        if (_preparedParticipant?.ParticipantID != participant.ParticipantID) 
            return;

        await RaceService.StartRaceAsync(race.Id, participant.ParticipantID);
        _preparedParticipant = null;

        await LoadRaces();
    }
}
