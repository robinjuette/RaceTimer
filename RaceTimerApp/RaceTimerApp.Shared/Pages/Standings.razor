@page "/standings"
@page "/standings/{RaceId}"
@using BlazorBootstrap
@using RaceTimerApp.Shared.Services
@using RaceTimerApp.Shared.Models;
@using RaceTimer.Shared.Models
@inject RaceManagementService RaceService
@inject RankingService RankingService
@inject TimingService TimingService
@inject NavigationManager Navigation

<div class="page-header">
    <h1>Zwischenstand</h1>
</div>


<div>

</div>

<div class="standings-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 20px;">
    @foreach (var race in DisplayedRaces)
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@race.Name</h5>
            </div>
            <div class="card-body">
                @if (rankings.TryGetValue(race.Id, out List<RankingEntry>? ranks))
                {
                    <ol class="standings-list">
                        @foreach (RankingEntry rankingEntry in ranks)
                        {
                            <li class="standing-item @(rankingEntry.CompletelyFinished ? "finished" : "active")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>
                                        <strong>#@rankingEntry.RaceParticipant.ParticipantNr</strong>
                                        @rankingEntry.RaceParticipant.Participant?.DisplayName
                                        @if (rankingEntry.CompletelyFinished)
                                        {
                                            <span class="badge bg-success ms-2">fertig</span>
                                        }
                                    </span>
                                    <span class="badge badge-lg @(rankingEntry.CompletelyFinished ? "bg-success" : "bg-info")">

                                        @rankingEntry.RunTime.ToString(@"hh\:mm\:ss")

                                    </span>
                                </div>
                                <Progress Class="mb-3">
                                    <ProgressBar Width="rankingEntry.ProgressPercent"/>
                                </Progress>
                                

                            </li>
                        }
                    </ol>
                }
                else
                {
                    <div class="text-muted">Keine Teilnehmer</div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? RaceId { get; set; }

    private SemaphoreSlim refreshSemaphore = new(1);
    private CancellationTokenSource? refreshCTS;

    private TimeSpan inactiveReloadDelay = TimeSpan.FromMinutes(1);
    private TimeSpan activeReloadDelay = TimeSpan.FromSeconds(20);

    private List<Race> RunningRaces = [];
    private List<Race> DisplayedRaces = [];
    private Dictionary<Guid, List<RankingEntry>> rankings = new();

    private TimingServiceUpdateEndpoint? updateEndpoint;

    private bool RunningRacesAvailable
    {
        get => (RunningRaces.Count == DisplayedRaces.Count &&
            RunningRaces.All(DisplayedRaces.Contains) &&
            !string.IsNullOrWhiteSpace(RaceId));
    }

    protected override async Task OnInitializedAsync()
    {
        updateEndpoint = new(TimePointUpdated);
        TimingService.RegisterForCallback(updateEndpoint);
        await LoadRaces();
    }

    private async void TimePointUpdated(RaceParticipantTimePoint? tp)
    {
        await LoadRaces();
        StateHasChanged();
    }

    private async Task LoadRaces()
    {
        List<Race> displayedRaces = new();

        RunningRaces = (await RaceService.GetRunningRacesAsync()).ToList();

        if (!string.IsNullOrWhiteSpace(RaceId) && 
            Guid.TryParse(RaceId, out Guid raceGuid))
        {
            if(RunningRaces.FirstOrDefault(r => r.Id == raceGuid) is Race runningRace)
            {
                displayedRaces.Add(runningRace);
            }
            else if (await RaceService.GetRaceAsync(raceGuid) is Race race)
            {
                displayedRaces.Add(race);
            }
        }

        if(displayedRaces.Count == 0)
        {
            displayedRaces.AddRange(RunningRaces);
        }

        DisplayedRaces = displayedRaces;

        rankings.Clear();

        foreach(Race RunningRace in DisplayedRaces)
        {
            rankings[RunningRace.Id] = await RankingService.GetRankingsAsync(RunningRace.Id);
        }

        AutoRefreshUI();
    }

    private void SwitchToRunningRaces()
    {
        Navigation.NavigateTo("/standings");
    }

    private async void AutoRefreshUI()
    {
        if(refreshSemaphore.CurrentCount == 0)
        {
            return;
        }

        CancellationTokenSource cancellationTokenSource = new();
        refreshCTS = cancellationTokenSource;

        TimeSpan timeSpan = TimeSpan.FromSeconds(1);

        while(DisplayedRaces.Any(RunningRaces.Contains) && 
            !cancellationTokenSource.IsCancellationRequested)
        {
            await Task.Delay(timeSpan);
            StateHasChanged();
        }
    }

}
