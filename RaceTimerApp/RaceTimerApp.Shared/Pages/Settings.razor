@page "/settings"
@using RaceTimerApp.Shared.Services
@using RaceTimerApp.Shared.Models
@inject SettingsService SettingsService

<div class="page-header">
    <h1>Einstellungen</h1>
</div>

<div class="settings-container">
    <!-- Betriebsmodus -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Betriebsmodus</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Modus:</label>
                <select class="form-select" @bind="_currentMode">
                    <option value="StandaloneServer">Standalone-Server (lokal)</option>
                    <option value="RemoteServer">Remote-Server</option>
                </select>
                <small class="form-text text-muted">
                    Standalone: Server läuft lokal auf diesem Gerät<br/>
                    Remote: Verbindung zu einem externen Server
                </small>
            </div>
        </div>
    </div>

    <!-- Standalone Server Einstellungen -->
    @if (_currentMode == "StandaloneServer")
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5>Server-Konfiguration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Server-Port:</label>
                    <input type="number" class="form-control" @bind="_appSettings.ServerPort" />
                    <small class="form-text text-muted">Standard: 5000</small>
                </div>

                <button class="btn btn-secondary" @onclick="TestServerConnection">Server testen</button>
                @if (_serverTestResult is not null)
                {
                    <div class="alert alert-@(_serverTestResult.Value ? "success" : "danger") mt-2">
                        @(_serverTestResult.Value ? "✓ Server erreichbar" : "✗ Server nicht erreichbar")
                    </div>
                }
            </div>
        </div>

        <!-- Datenbankverbindung -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>Datenbankverbindung</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Datenbanktyp:</label>
                    <select class="form-select" @bind="_appSettings.DatabaseType">
                        <option value="Sqlite">SQLite (lokal)</option>
                        <option value="SqlServer">SQL Server</option>
                    </select>
                </div>

                @if (_appSettings.DatabaseType == "Sqlite")
                {
                    <div class="mb-3">
                        <label class="form-label">Datenbankpfad:</label>
                        <input type="text" class="form-control" @bind="_appSettings.DatabasePath" />
                        <small class="form-text text-muted">Standard: Data/racetimer.db</small>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">SQL Server Verbindungsstring:</label>
                        <textarea class="form-control" rows="3" @bind="_appSettings.SqlServerConnectionString" placeholder="Server=localhost;Database=RaceTimer;..."></textarea>
                    </div>
                }

                <div class="d-grid gap-2">
                    <button class="btn btn-secondary" @onclick="TestDatabaseConnection">Verbindung testen</button>
                    @if (_databaseTestResult is not null)
                    {
                        <div class="alert alert-@(_databaseTestResult.Value ? "success" : "danger")">
                            @(_databaseTestResult.Value ? "✓ Datenbankverbindung erfolgreich" : "✗ Datenbankverbindung fehlgeschlagen")
                        </div>
                    }
                    @if (_appSettings.IsDatabaseMigrationNeeded)
                    {
                        <button class="btn btn-warning" @onclick="RunDatabaseMigration">Datenbank migrieren</button>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Remote Server Einstellungen -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>Server-Verbindung</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Server-URL:</label>
                    <input type="url" class="form-control" @bind="_appSettings.ServerUrl" placeholder="http://localhost:5000" />
                </div>

                <button class="btn btn-secondary" @onclick="TestServerConnection">Verbindung testen</button>
                @if (_serverTestResult is not null)
                {
                    <div class="alert alert-@(_serverTestResult.Value ? "success" : "danger") mt-2">
                        @(_serverTestResult.Value ? "✓ Server erreichbar" : "✗ Server nicht erreichbar")
                    </div>
                }
            </div>
        </div>
    }

    <!-- Allgemeine Einstellungen -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Allgemeine Einstellungen</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Zwischenstand-Update-Intervall (Sekunden):</label>
                <input type="number" class="form-control" @bind="_appSettings.StatusUpdateIntervalSeconds" min="10" />
                <small class="form-text text-muted">Intervall für Aktualisierung der Übersichtsseite. Standard: 60 Sekunden</small>
            </div>
        </div>
    </div>

    <!-- Save Button -->
    <div class="d-grid">
        <button class="btn btn-primary btn-lg" @onclick="SaveSettings">Einstellungen speichern</button>
    </div>

    @if (_saveMessage is not null)
    {
        <div class="alert alert-@(_saveMessage.Value.IsSuccess ? "success" : "danger") mt-3">
            @_saveMessage.Value.Message
        </div>
    }
</div>

@code {
    private AppSettings _appSettings = new();
    private string _currentMode = "StandaloneServer";
    private bool? _serverTestResult;
    private bool? _databaseTestResult;
    private (bool IsSuccess, string Message)? _saveMessage;

    protected override void OnInitialized()
    {
        _appSettings = SettingsService.GetSettings();
        _currentMode = _appSettings.Mode;
    }

    private async Task TestServerConnection()
    {
        var url = _currentMode == "StandaloneServer" 
            ? $"http://localhost:{_appSettings.ServerPort}"
            : _appSettings.ServerUrl;

        _serverTestResult = await SettingsService.TestServerConnectionAsync(url);
    }

    private async Task TestDatabaseConnection()
    {
        _databaseTestResult = await SettingsService.TestDatabaseConnectionAsync(_appSettings);
    }

    private async Task RunDatabaseMigration()
    {
        var success = await SettingsService.RunDatabaseMigrationAsync(_appSettings);
        if (success)
        {
            _appSettings.IsDatabaseMigrationNeeded = false;
            _saveMessage = (true, "Datenbankmigrationen erfolgreich durchgeführt");
        }
        else
        {
            _saveMessage = (false, "Migration fehlgeschlagen");
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            _appSettings.Mode = _currentMode;
            await SettingsService.SaveSettingsAsync(_appSettings);
            _saveMessage = (true, "Einstellungen gespeichert");
        }
        catch (Exception ex)
        {
            _saveMessage = (false, $"Fehler beim Speichern: {ex.Message}");
        }
    }
}
