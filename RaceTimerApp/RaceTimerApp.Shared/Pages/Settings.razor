@page "/settings"
@using RaceTimerApp.Shared.Services
@using RaceTimerApp.Shared.Models
@inject AppConfigService AppConfigService
@inject SettingsService SettingsService

<div class="page-header">
    <h1>Einstellungen</h1>
</div>

<div class="settings-container">
    <!-- Betriebsmodus -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Betriebsmodus</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Modus:</label>
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" id="offline_mode" name="mode" value="Offline" @onchange="@((ChangeEventArgs e) => HandleModeChange(e.Value?.ToString() ?? ""))" 
                           checked="@(AppConfigService.Settings.Mode == "Offline")" />
                    <label class="btn btn-outline-primary" for="offline_mode">
                        Offline (nur lokal)
                    </label>

                    <input type="radio" class="btn-check" id="online_mode" name="mode" value="Online" @onchange="@((ChangeEventArgs e) => HandleModeChange(e.Value?.ToString() ?? ""))" 
                           checked="@(AppConfigService.Settings.Mode == "Online")" />
                    <label class="btn btn-outline-primary" for="online_mode">
                        Online (mit Server)
                    </label>
                </div>
                <small class="form-text text-muted d-block mt-2">
                    Offline: Die App funktioniert komplett lokal. Daten werden nur auf diesem Gerät gespeichert.<br/>
                    Online: Verbindung zu einem externen Server für Synchronisierung in Echtzeit.
                </small>
            </div>
        </div>
    </div>

    <!-- Server-Verbindung (nur im Online-Modus) -->
    @if (AppConfigService.Settings.Mode == "Online")
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5>Server-Konfiguration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Server-URL:</label>
                    <input type="url" class="form-control" @bind="serverUrl" placeholder="https://raceserver.example.com" />
                    <small class="form-text text-muted">Bsp: https://racetimer-api.herokuapp.com</small>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-success" @onclick="ConnectToServer" disabled="@isConnecting">
                        @if (isConnecting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <text>Verbinde...</text>
                        }
                        else if (AppConfigService.IsServerConnected)
                        {
                            <span class="badge bg-success me-2">✓</span>
                            <text>Verbunden - Trennen</text>
                        }
                        else
                        {
                            <text>Verbinden</text>
                        }
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(connectionMessage))
                {
                    <div class="alert alert-@(connectionSuccess ? "success" : "danger") mt-2">
                        @connectionMessage
                    </div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5>Synchronisierung</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Auto-Sync Intervall (Sekunden):</label>
                    <input type="number" class="form-control" @bind="AppConfigService.Settings.SyncIntervalSeconds" min="10" max="300" />
                    <small class="form-text text-muted">Wie oft die App mit dem Server synchronisiert. Standard: 30 Sekunden</small>
                </div>
            </div>
        </div>
    }

    <!-- Lokale Einstellungen -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Lokale Datenspeicherung</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Datenbankpfad:</label>
                <input type="text" class="form-control" @bind="AppConfigService.Settings.DatabasePath" readonly />
                <small class="form-text text-muted">Die Datenbank wird lokal im App-Datenverzeichnis gespeichert</small>
            </div>
        </div>
    </div>

    <!-- Allgemeine Einstellungen -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Allgemeine Einstellungen</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Status-Update Intervall (Sekunden):</label>
                <input type="number" class="form-control" @bind="AppConfigService.Settings.StatusUpdateIntervalSeconds" min="10" />
                <small class="form-text text-muted">Intervall für Aktualisierung der Anzeigeseiten. Standard: 60 Sekunden</small>
            </div>
        </div>
    </div>

    <!-- Save Button -->
    <div class="d-grid">
        <button class="btn btn-primary btn-lg" @onclick="SaveSettings">Einstellungen speichern</button>
    </div>

    @if (!string.IsNullOrEmpty(saveMessage))
    {
        <div class="alert alert-@(saveSuccess ? "success" : "danger") mt-3">
            @saveMessage
        </div>
    }
</div>

@code {
    private string serverUrl = "";
    private string? connectionMessage;
    private bool connectionSuccess;
    private bool isConnecting;
    private string? saveMessage;
    private bool saveSuccess;

    protected override void OnInitialized()
    {
        serverUrl = AppConfigService.Settings.ServerUrl ?? "";
    }

    private async Task HandleModeChange(string newMode)
    {
        if (newMode == "Online" && AppConfigService.Settings.Mode == "Offline")
        {
            // Schalte auf Online um
            AppConfigService.Settings.Mode = "Online";
            AppConfigService.SaveSettings(AppConfigService.Settings);
        }
        else if (newMode == "Offline" && AppConfigService.Settings.Mode == "Online")
        {
            // Schalte auf Offline um
            await AppConfigService.DisconnectFromServerAsync();
            AppConfigService.Settings.Mode = "Offline";
            AppConfigService.SaveSettings(AppConfigService.Settings);
        }
    }

    private async Task ConnectToServer()
    {
        if (AppConfigService.IsServerConnected)
        {
            // Trennen
            isConnecting = true;
            await AppConfigService.DisconnectFromServerAsync();
            connectionMessage = "Vom Server getrennt";
            isConnecting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(serverUrl))
        {
            connectionMessage = "Bitte Server-URL eingeben";
            connectionSuccess = false;
            return;
        }

        isConnecting = true;
        connectionMessage = null;

        var connected = await AppConfigService.ConnectToServerAsync(serverUrl);
        connectionSuccess = connected;
        connectionMessage = connected 
            ? "✓ Erfolgreich mit Server verbunden!" 
            : "✗ Verbindung zum Server fehlgeschlagen. Prüfen Sie die URL und stellen Sie sicher, dass der Server erreichbar ist.";

        isConnecting = false;

        if (connected)
        {
            serverUrl = AppConfigService.Settings.ServerUrl ?? "";
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            AppConfigService.SaveSettings(AppConfigService.Settings);
            saveMessage = "✓ Einstellungen gespeichert";
            saveSuccess = true;
        }
        catch (Exception ex)
        {
            saveMessage = $"✗ Fehler beim Speichern: {ex.Message}";
            saveSuccess = false;
        }
    }
}

